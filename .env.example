# ============================================================
# .env ফাইল টেমপ্লেট
# এই ফাইলের নাম .env রাখুন এবং আপনার তথ্য দিন
# ============================================================

# ---- টেলিগ্রাম বট টোকেন ----
# @BotFather থেকে /newbot কমান্ড দিয়ে বট তৈরি করুন
# তারপর টোকেন কপি করে নিচে পেস্ট করুন
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ---- অনুমোদিত ইউজার ----
# @userinfobot থেকে আপনার Telegram ID বের করুন
# একাধিক ইউজার হলে কমা দিয়ে আলাদা করুন
# খালি রাখলে সবাই ব্যবহার করতে পারবে
ALLOWED_USERS=

# ---- OTP পোলিং ইন্টারভাল (সেকেন্ড) ----
# কত সেকেন্ড পর পর নতুন OTP চেক করবে
# কম মান = দ্রুত OTP কিন্তু বেশি রিকোয়েস্ট
OTP_POLL_INTERVAL=3

# ---- SMS প্যানেল লগইন তথ্য ----

# Wolf SMS (213.32.24.208)
WOLF_USERNAME=your_wolf_username
WOLF_PASSWORD=your_wolf_password

# RoxySMS (roxysms.net)
ROXY_USERNAME=your_roxy_username
ROXY_PASSWORD=your_roxy_password

# Lamix SMS (51.210.208.26)
LAMIX_USERNAME=your_lamix_username
LAMIX_PASSWORD=your_lamix_password

# SMS Hadi (smshadi.net)
HADI_USERNAME=your_hadi_username
HADI_PASSWORD=your_hadi_password

# ---- ডেটাবেস পাথ ----
DB_PATH=./data/otp_bot.db
